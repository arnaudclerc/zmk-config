#include <behaviors/studio_unlock.dtsi>
#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/ext_power.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/outputs.h>

#define DEF 0
#define NUM 1
#define VIM 2
#define MEDIA 3
#define ADJ 4
#define GAME 5
#define QUICK_TAP_MS 125
#define TAPPING_TERM_MS 200

&sk {
    release-after-ms = <600>;
    quick-release;
};

/ {
    conditional_layers {
        compatible = "zmk,conditional-layers";

        tri_layer {
            if-layers = <DEF NUM>;
            then-layer = <ADJ>;
        };
    };

    macros {
        sel_word: sel_word {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LC(LEFT) &kp LS(RIGHT)>;
            label = "SEL_WORD";
        };

        sel_line: sel_line {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp HOME &kp LS(END)>;
            label = "SEL_LINE";
        };
    };

    combos {
        compatible = "zmk,combos";

        caps {
            timeout-ms = <50>;
            key-positions = <16 19>;  // T and N (home row Caps Word)
            bindings = <&caps_word>;
            layers = <DEF>;
        };

        dollar {
            timeout-ms = <50>;
            key-positions = <3 8>;  // F and U
            bindings =<&kp DOLLAR>;
            layers = <DEF>;
        };

        lesser {
            timeout-ms = <50>;
            key-positions = <2 3>;  // W and F
            bindings =<&kp LESS_THAN>;
            layers = <DEF>;
        };

        lft_bracket {
            timeout-ms = <50>;
            key-positions = <3 4>;  // F and P
            bindings =<&kp LBKT>;
            layers = <DEF>;
        };

        pipe {
            timeout-ms = <50>;
            key-positions = <4 5>;  // P and B
            bindings =<&kp PIPE>;
            layers = <DEF>;
        };

        underscore {
            timeout-ms = <50>;
            key-positions = <6 7>;  // J AND L
            bindings =<&kp UNDERSCORE>;
            layers = <DEF>;
        };

        rg_bracket {
            timeout-ms = <50>;
            key-positions = <7 8>;  // L AND U
            bindings =<&kp RBKT>;
            layers = <DEF>;
        };

        greater {
            timeout-ms = <50>;
            key-positions = <8 9>;  // U and Y
            bindings =<&kp GREATER_THAN>;
            layers = <DEF>;
        };

        equal {
            timeout-ms = <50>;
            key-positions = <13 14>;  // A and R
            bindings =<&kp EQUAL>;
            layers = <DEF>;
        };

        plus {
            timeout-ms = <50>;
            key-positions = <14 15>;  // R and S
            bindings =<&kp PLUS>;
            layers = <DEF>;
        };

        lf_parenthesis {
            timeout-ms = <50>;
            key-positions = <15 16>;  // S and T
            bindings =<&kp LPAR>;
            layers = <DEF>;
        };

        hash {
            timeout-ms = <50>;
            key-positions = <16 17>;  // T and G
            bindings =<&kp HASH>;
            layers = <DEF>;
        };

        at {
            timeout-ms = <50>;
            key-positions = <17 18>;  // M and N
            bindings =<&kp AT>;
            layers = <DEF>;
        };

        rg_parenthesis {
            timeout-ms = <50>;
            key-positions = <18 19>;  // N and E
            bindings =<&kp RPAR>;
            layers = <DEF>;
        };

        minus {
            timeout-ms = <50>;
            key-positions = <19 20>;  // E and I
            bindings =<&kp MINUS>;
            layers = <DEF>;
        };

        asterisk {
            timeout-ms = <50>;
            key-positions = <21 21>;  // I and O
            bindings =<&kp ASTERISK>;
            layers = <DEF>;
        };

        lf_brace {
            timeout-ms = <50>;
            key-positions = <27 28>;  // C and D
            bindings =<&kp LBRC>;
            layers = <DEF>;
        };

        percent {
            timeout-ms = <50>;
            key-positions = <28 29>;  // D and V
            bindings =<&kp PRCNT>;
            layers = <DEF>;
        };

        caret {
            timeout-ms = <50>;
            key-positions = <30 31>;  // K and H
            bindings =<&kp CARET>;
            layers = <DEF>;
        };

        rg_brace {
            timeout-ms = <50>;
            key-positions = <31 32>;  // H and DOT
            bindings =<&kp RBRC>;
            layers = <DEF>;
        };

        ampersand {
            timeout-ms = <50>;
            key-positions = <32 33>;  // DOT and EXCLAM
            bindings =<&kp AMPERSAND>;
            layers = <DEF>;
        };

        cut {
            timeout-ms = <50>;
            key-positions = <7 8>;  // g AND o
            bindings =<&kp X>;
            layers = <VIM>;
        };

        delete {
            timeout-ms = <50>;
            key-positions = <8 9>;  // o AND u
            bindings =<&kp D>;
            layers = <VIM>;
        };

        paste {
            timeout-ms = <50>;
            key-positions = <19 20>;  // h AND j
            bindings =<&kp P>;
            layers = <VIM>;
        };

        yank {
            timeout-ms = <50>;
            key-positions = <20 21>;  // j AND k
            bindings =<&kp Y>;
            layers = <VIM>;
        };

        visual {
            timeout-ms = <50>;
            key-positions = <31 32>;  // i AND a
            bindings =<&kp V>;
            layers = <VIM>;
        };

        next-prev {
            timeout-ms = <50>;
            key-positions = <32 33>;  // a AND DOT
            bindings =<&kp COMMA>;
            layers = <VIM>;
        };
    };

    behaviors {
        lq: layer_toggle_quick {
            compatible = "zmk,behavior-hold-tap";
            label = "Layer Toggle Quick";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <TAPPING_TERM_MS>;
            quick-tap-ms = <QUICK_TAP_MS>;
            bindings = <&mo>, <&kp>;
        };

        ht: hold_tap {
            compatible = "zmk,behavior-hold-tap";
            label = "Hold Tap";
            display-name = "Hold-Tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <TAPPING_TERM_MS>;
            quick-tap-ms = <QUICK_TAP_MS>;
            bindings = <&kp>, <&kp>;
        };

        htb: hold_tap_balanced {
            compatible = "zmk,behavior-hold-tap";
            label = "Hold Tap Balanced";
            #binding-cells = <2>;
            flavor = "balanced";
            tapping-term-ms = <TAPPING_TERM_MS>;
            quick-tap-ms = <QUICK_TAP_MS>;
            bindings = <&kp>, <&kp>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        default_layer {
            display-name = "Default";
            bindings = <
    &ht 1 GRAVE    &ht N1 Q     &ht N2 W    &ht N3 F        &ht N4 P        &ht N5 B        &ht N6 J    &ht N7 L                &ht N8 U        &ht N9 Y            &ht COLON SEMI  &kp BSPC
    &kp TAB        &kp A        &kp R       &ht LGUI S      &htb LSHIFT T   &kp G           &kp M       &htb LSHIFT N           &ht LGUI E      &kp I               &kp O           &kp DQT
    &kp TILDE      &kp Z        &kp X       &kp C           &kp D           &kp V           &kp K       &kp H                   &ht DOT COMMA   &ht QMARK EXCL      &ht FSLH BSLH   &kp SQT
                                                            &none                                       &none
                                &sel_word   &ht K_CUT BSPC  &ht LGUI SPACE  &ht LCTRL RS(LS(LEFT))      &ht RALT RS(LS(RIGHT))  &lq NUM DEL     &ht K_PASTE K_AGAIN &sel_line
            >;

            sensor-bindings = <&inc_dec_kp PG_UP PG_DN &inc_dec_kp C_VOL_UP C_VOL_DN>;
        };

        sym_layer {
            display-name = "Symbols";
            bindings = <
    &trans   &kp EXCL   &kp AT     &kp HASH   &kp DLLR   &kp PRCNT       &kp CARET   &kp AMPS   &kp KP_MULTIPLY    &kp LPAR   &kp RPAR   &kp BSPC
    &trans   &trans     &trans     &trans     &trans     &trans          &kp MINUS   &kp EQUAL  &kp LBKT           &kp RBKT   &kp BSLH   &kp GRAVE
    &trans   &trans     &trans     &trans     &trans     &trans          &kp UNDER   &kp PLUS   &kp LBRC           &kp RBRC   &kp PIPE   &kp TILDE
                                                        &none                                       &none
                        &trans     &trans     &trans     &trans                        &trans     &trans             &trans     &trans
            >;

            sensor-bindings = <&inc_dec_kp UP DOWN &inc_dec_kp C_NEXT C_PREV>;
        };

        num_layer {
            display-name = "Numbers";
            bindings = <
    &kp TAB  &ht F1 N1    &ht F2 N2    &ht F3 N3    &ht F4 N4    &ht F5 N5        &ht F6 N6  &ht F7 N7  &ht F8 N8  &ht F9 N9   &ht F10 N0    &trans
    &trans   &trans       &trans       &trans       &trans       &trans           &kp LEFT   &kp DOWN   &kp UP     &kp RIGHT   &trans        &trans
    &trans   &trans       &trans       &trans       &trans       &trans           &kp HOME   &kp PG_DN  &kp PG_UP  &kp END     &trans        &trans
                                                     &trans                                                          &trans
                          &trans       &trans       &trans       &trans                        &trans     &trans     &trans      &trans
            >;

            sensor-bindings = <&inc_dec_kp HOME END &inc_dec_kp C_NEXT C_PREV>;
        };

        adj_layer {
            display-name = "Adjust";
            bindings = <
    &bootloader   &trans         &trans         &trans         &trans         &trans             &out OUT_TOG     &trans   &trans     &trans         &trans       &bootloader
    &sys_reset    &trans         &trans         &trans         &trans         &trans             &studio_unlock   &trans   &trans     &trans         &trans       &sys_reset
    &bt BT_CLR    &bt BT_SEL 0   &bt BT_SEL 1   &bt BT_SEL 2   &bt BT_SEL 3   &bt BT_SEL 4       &kp C_PREV       &kp C_PP &kp C_NEXT &kp C_VOL_UP   &kp C_MUTE   &kp C_VOL_DN
                                                                 &trans                                                      &trans
                                  &ext_power EP_TOG &trans      &trans         &trans                               &trans   &trans     &trans         &trans
            >;

            // F15 and F14 are brightness controls for macOS
            sensor-bindings = <&inc_dec_kp F15 F14 &inc_dec_kp PG_UP PG_DN>;
        };
    };
};
